SITE_URL=https://whats-new.kr
BACKLOG_QUEUE_BATCH_SIZE=25
AUTH_ENFORCEMENT=on
TRUSTED_IP_BYPASS=on

# Optional: Slack or Discord webhook for ingestion alerts
ALERT_WEBHOOK_URL=

# Optional: comma-separated admin IP allowlist for write endpoints
ALLOWED_ADMIN_IPS=

# Required in production: JSON array of bearer tokens for admin/MCP access
API_KEY_RING=[]
