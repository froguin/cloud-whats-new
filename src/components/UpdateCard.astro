---
interface Props {
  title: string;
  date: number;
  content: string;
  target?: string;
  features?: string;
  regions?: string;
  status?: string;
  originalLink?: string;
}

const { title, date, content, target, features, regions, status, originalLink } = Astro.props;

// 날짜 포맷팅
const formatDate = (timestamp: number) => {
  return new Date(timestamp).toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'Asia/Seoul'
  });
};

// 상태에 따른 배지 색상 결정
const getStatusBadge = (status: string) => {
  const statusLower = status?.toLowerCase() || '';
  if (statusLower.includes('미리보기') || statusLower.includes('preview')) {
    return { text: '미리보기', class: 'bg-yellow-100 dark:bg-yellow-900 text-yellow-800 dark:text-yellow-200' };
  } else if (statusLower.includes('베타') || statusLower.includes('beta')) {
    return { text: '베타', class: 'bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200' };
  } else {
    return { text: '정식 출시', class: 'bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200' };
  }
};

const formattedDate = formatDate(date);
const statusBadge = getStatusBadge(status || '정식 출시');
---

<article class="update-card bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300 overflow-hidden">
  <div class="p-6">
    <div class="flex items-center justify-between mb-4">
      <time datetime={new Date(date).toISOString()} class="text-sm font-medium text-gray-500 dark:text-gray-400">
        {formattedDate}
      </time>
      <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusBadge.class}`}>
        {statusBadge.text}
      </span>
    </div>
    
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4 line-clamp-2 hover:line-clamp-none">
      {title}
    </h2>
    
    <div class="prose prose-sm text-gray-600 dark:text-gray-300 mb-4">
      <div class="line-clamp-3 hover:line-clamp-none whitespace-pre-wrap">
        {content}
      </div>
    </div>

    <!-- 추가 정보 섹션 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4 text-sm">
      {target && (
        <div class="flex items-start space-x-2">
          <span class="font-medium text-gray-500 dark:text-gray-400 min-w-0 flex-shrink-0">대상:</span>
          <span class="text-gray-700 dark:text-gray-300">{target}</span>
        </div>
      )}
      
      {features && (
        <div class="flex items-start space-x-2">
          <span class="font-medium text-gray-500 dark:text-gray-400 min-w-0 flex-shrink-0">주요기능:</span>
          <span class="text-gray-700 dark:text-gray-300">{features}</span>
        </div>
      )}
      
      {regions && (
        <div class="flex items-start space-x-2">
          <span class="font-medium text-gray-500 dark:text-gray-400 min-w-0 flex-shrink-0">지원리전:</span>
          <span class="text-gray-700 dark:text-gray-300">{regions}</span>
        </div>
      )}
    </div>
  </div>

  {originalLink && (
    <div class="px-6 py-4 bg-gray-50 dark:bg-gray-700 border-t border-gray-100 dark:border-gray-600">
      <a 
        href={originalLink} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="inline-flex items-center text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors duration-200"
      >
        자세히 보기
        <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  )}
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .hover\:line-clamp-none:hover {
    display: block;
    -webkit-line-clamp: unset;
    -webkit-box-orient: unset;
    overflow: visible;
  }

  /* 다크 테마에서 텍스트 가독성 개선 */
  .dark .prose {
    color: rgb(209 213 219); /* gray-300 */
  }
  
  .dark .prose strong {
    color: rgb(243 244 246); /* gray-100 */
  }
  
  .dark .prose a {
    color: rgb(96 165 250); /* blue-400 */
  }
  
  .dark .prose a:hover {
    color: rgb(147 197 253); /* blue-300 */
  }
</style>
