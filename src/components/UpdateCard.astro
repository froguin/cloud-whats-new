---
import Container from '@cloudscape-design/components/container';
import Header from '@cloudscape-design/components/header';
import SpaceBetween from '@cloudscape-design/components/space-between';
import Link from '@cloudscape-design/components/link';

interface Props {
  title: string;
  date: string;
  content: string;
  target?: string;
  features?: string;
  regions?: string;
  status?: string;
  originalLink?: string;
}

const { title, date, content, target, features, regions, status, originalLink } = Astro.props;
---

<Container>
  <SpaceBetween size="m">
    <div>
      <Header variant="h2">{title}</Header>
      <div class="text-sm text-aws-gray-600">{date}</div>
    </div>
    
    <div class="prose prose-sm text-aws-gray-600">
      <div set:html={content} />
    </div>

    <SpaceBetween size="s">
      {target && (
        <div>
          <strong>대상:</strong> {target}
        </div>
      )}
      {features && (
        <div>
          <strong>주요 기능:</strong> {features}
        </div>
      )}
      {regions && (
        <div>
          <strong>지원 리전:</strong> {regions}
        </div>
      )}
    </SpaceBetween>

    {originalLink && (
      <Link href={originalLink} external>
        자세히 보기
      </Link>
    )}
  </SpaceBetween>
</Container>
