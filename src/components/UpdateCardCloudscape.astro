---
interface Props {
  title: string;
  date: string;
  content: string;
  csp?: string;
  target?: string;
  features?: string;
  regions?: string;
  status?: string;
  originalLink?: string;
}

const { title, date, content, csp, target, features, regions, status, originalLink } = Astro.props;

let statuses: string[] = [];
try {
  if (status) {
    const parsed = JSON.parse(status);
    statuses = Array.isArray(parsed) ? parsed.filter((s: string) => !s.includes(':')) : [status];
  }
} catch { statuses = status ? [status] : []; }

const statusColors: Record<string, string> = {
  '정식 출시': 'background:#dcfce7;color:#166534;',
  '미리보기': 'background:#dbeafe;color:#1e40af;',
  '베타': 'background:#f3e8ff;color:#6b21a8;',
  '지원 종료': 'background:#fee2e2;color:#991b1b;',
};

const cspBadge: Record<string, { label: string; bg: string; text: string }> = {
  aws:   { label: 'AWS',   bg: '#FF9900', text: '#000716' },
  gcp:   { label: 'GCP',   bg: '#34A853', text: '#FFFFFF' },
  azure: { label: 'Azure', bg: '#0078D4', text: '#FFFFFF' },
};
const badge = csp ? cspBadge[csp] : null;
---

<a href={originalLink || '#'} target="_blank" rel="noopener noreferrer"
  class="card-link block group overflow-hidden no-underline transition-all duration-200"
  style={`background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);box-shadow:var(--card-shadow);`}>
  <div class="p-4">
    <div class="flex items-center gap-1.5 mb-2 flex-wrap">
      {badge && (
        <span class="px-1.5 py-0.5 rounded text-[11px] font-bold leading-none" style={`background:${badge.bg};color:${badge.text};`}>
          {badge.label}
        </span>
      )}
      {statuses.map(s => (
        <span class="px-1.5 py-0.5 rounded text-[11px] font-medium leading-none" style={statusColors[s] || `background:color-mix(in srgb,var(--color-primary) 15%,transparent);color:var(--color-primary);`}>
          {s}
        </span>
      ))}
      {date && <time class="text-[11px] ml-auto" style="color:var(--color-text-secondary);">{date}</time>}
    </div>

    <h3 class="text-sm font-bold mb-2 leading-snug line-clamp-2 group-hover:line-clamp-none" style="color:var(--color-text-primary);word-break:break-word;">
      {title}
    </h3>

    <p class="text-xs leading-relaxed line-clamp-3 group-hover:line-clamp-none" style="color:var(--color-text-secondary);">
      {content}
    </p>
  </div>

  {(target || features || regions) && (
    <div class="px-4 pb-3 space-y-1 text-[11px] hidden group-hover:block" style="border-top:1px solid var(--color-border);padding-top:8px;">
      {target && <div><span class="font-medium" style="color:var(--color-primary);">대상</span> <span style="color:var(--color-text-secondary);">{target}</span></div>}
      {features && <div><span class="font-medium" style="color:var(--color-primary);">기능</span> <span style="color:var(--color-text-secondary);">{features}</span></div>}
      {regions && <div><span class="font-medium" style="color:var(--color-primary);">리전</span> <span style="color:var(--color-text-secondary);">{regions}</span></div>}
    </div>
  )}

  <div class="px-4 py-2 text-xs font-medium transition-colors" style="border-top:1px solid var(--color-border);color:var(--color-primary);">
    자세히 보기 →
  </div>
</a>

<style>
  .card-link:hover {
    box-shadow: var(--card-hover-shadow) !important;
    transform: translateY(-2px);
  }
</style>
