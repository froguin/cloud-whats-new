---
interface Props {
  title: string;
  date: string;
  content: string;
  csp?: string;
  target?: string;
  features?: string;
  regions?: string;
  status?: string;
  originalLink?: string;
}

const { title, date, content, csp, target, features, regions, status, originalLink } = Astro.props;

let statuses: string[] = [];
try {
  if (status) {
    const parsed = JSON.parse(status);
    statuses = Array.isArray(parsed) ? parsed.filter((s: string) => !s.includes(':')) : [status];
  }
} catch { statuses = status ? [status] : []; }

const statusColors: Record<string, string> = {
  '정식 출시': 'background:#dcfce7;color:#166534;',
  '미리보기': 'background:#dbeafe;color:#1e40af;',
  '베타': 'background:#f3e8ff;color:#6b21a8;',
  '지원 종료': 'background:#fee2e2;color:#991b1b;',
};

const cspBadge: Record<string, { label: string; bg: string; text: string }> = {
  aws:   { label: 'AWS',   bg: '#FF9900', text: '#000716' },
  gcp:   { label: 'GCP',   bg: '#1A73E8', text: '#FFFFFF' },
  azure: { label: 'Azure', bg: '#0078D4', text: '#FFFFFF' },
};
const badge = csp ? cspBadge[csp] : null;
const hasDetails = !!(target || features || regions);
---

<div class="card-wrapper group" style={`background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);box-shadow:var(--card-shadow);overflow:hidden;transition:all 0.2s;`}>
  <a href={originalLink || '#'} target="_blank" rel="noopener noreferrer" class="block no-underline p-4 sm:p-5">
    <div class="flex items-center gap-1.5 mb-2.5 flex-wrap">
      {badge && (
        <span class="px-1.5 py-0.5 rounded text-[11px] sm:text-xs font-bold leading-none" style={`background:${badge.bg};color:${badge.text};`}>
          {badge.label}
        </span>
      )}
      {statuses.map(s => (
        <span class="px-1.5 py-0.5 rounded text-[11px] sm:text-xs font-medium leading-none" style={statusColors[s] || `background:color-mix(in srgb,var(--color-primary) 15%,transparent);color:var(--color-primary);`}>
          {s}
        </span>
      ))}
      {date && <time class="text-[11px] sm:text-xs ml-auto shrink-0" style="color:var(--color-text-secondary);">{date}</time>}
    </div>

    <h3 class="text-sm sm:text-base font-bold mb-2 leading-snug" style="color:var(--color-text-primary);word-break:break-word;">
      {title}
    </h3>

    <p class="text-xs sm:text-sm leading-relaxed" style="color:var(--color-text-secondary);">
      {content}
    </p>
  </a>

  {hasDetails && (
    <div class="details-section" style="border-top:1px solid var(--color-border);">
      <!-- Mobile: always visible, toggle with tap -->
      <button class="details-toggle w-full px-4 sm:px-5 py-2 text-left text-xs font-medium sm:hidden" style="color:var(--color-primary);background:transparent;border:none;cursor:pointer;">
        상세 정보 ▾
      </button>
      <div class="details-content px-4 sm:px-5 pb-3 pt-1 space-y-1 text-[11px] sm:text-xs hidden sm:hidden group-hover:sm:block">
        {target && <div><span class="font-semibold" style="color:var(--color-primary);">대상</span> <span style="color:var(--color-text-secondary);">{target}</span></div>}
        {features && <div><span class="font-semibold" style="color:var(--color-primary);">기능</span> <span style="color:var(--color-text-secondary);">{features}</span></div>}
        {regions && <div><span class="font-semibold" style="color:var(--color-primary);">리전</span> <span style="color:var(--color-text-secondary);">{regions}</span></div>}
      </div>
    </div>
  )}
</div>

<style>
  .card-wrapper:hover {
    box-shadow: var(--card-hover-shadow) !important;
    transform: translateY(-2px);
  }
  @media (min-width: 640px) {
    .details-toggle { display: none !important; }
    .details-content { display: none !important; }
    .card-wrapper:hover .details-content { display: block !important; }
  }
</style>

<script>
  document.querySelectorAll('.details-toggle').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const content = btn.nextElementSibling as HTMLElement;
      const isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden');
      btn.textContent = isOpen ? '상세 정보 ▾' : '상세 정보 ▴';
    });
  });
</script>
