---
interface Props {
  title: string; date: string; content: string; csp?: string;
  target?: string; features?: string; regions?: string; status?: string;
  originalLink?: string; index?: number;
}

const { title, date, content, csp, target, features, regions, status, originalLink, index = 0 } = Astro.props;

let statuses: string[] = [];
try {
  if (status) { const p = JSON.parse(status); statuses = Array.isArray(p) ? p.filter((s: string) => !s.includes(':')) : [status]; }
} catch { statuses = status ? [status] : []; }

const statusColors: Record<string, string> = {
  '정식 출시': 'background:#dcfce7;color:#166534;',
  '미리보기': 'background:#dbeafe;color:#1e40af;',
  '베타': 'background:#f3e8ff;color:#6b21a8;',
  '지원 종료': 'background:#fee2e2;color:#991b1b;',
};

// GCP 4-color rotation
const gcpColors = ['#4285F4', '#EA4335', '#FBBC04', '#34A853'];
const gcpAccent = gcpColors[index % 4];

const hasDetails = !!(target || features || regions);
---

{csp === 'aws' ? (
  <!-- AWS Cloudscape: bordered, dense, orange accent -->
  <a href={originalLink || '#'} target="_blank" rel="noopener noreferrer"
    class="aws-card block no-underline overflow-hidden transition-all duration-200"
    style="background:var(--color-surface); border:2px solid var(--color-border); border-radius:8px; border-left:4px solid #0972D3;">
    <div class="p-4 sm:p-5">
      <div class="flex items-center gap-1.5 mb-2 flex-wrap">
        {statuses.map(s => <span class="px-1.5 py-0.5 rounded text-[11px] font-medium" style={statusColors[s] || ''}>{s}</span>)}
        {date && <time class="text-[11px] ml-auto" style="color:var(--color-text-secondary);">{date}</time>}
      </div>
      <h3 class="text-sm sm:text-base font-bold mb-2 leading-snug" style="color:var(--color-text-primary);word-break:break-word;">{title}</h3>
      <p class="text-xs sm:text-sm leading-relaxed line-clamp-3" style="color:var(--color-text-secondary);">{content}</p>
      {hasDetails && (
        <div class="mt-3 pt-2 space-y-1 text-[11px]" style="border-top:1px solid var(--color-border);">
          {target && <div><span class="font-semibold" style="color:#0972D3;">대상</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{target}</span></div>}
          {features && <div><span class="font-semibold" style="color:#0972D3;">기능</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{features}</span></div>}
          {regions && <div><span class="font-semibold" style="color:#0972D3;">리전</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{regions}</span></div>}
        </div>
      )}
    </div>
  </a>
) : csp === 'gcp' ? (
  <!-- GCP Material: rounded, floating, 4-color accent rotation -->
  <a href={originalLink || '#'} target="_blank" rel="noopener noreferrer"
    class="gcp-card block no-underline overflow-hidden transition-all duration-200"
    style={`background:var(--color-surface); border-radius:12px; box-shadow:var(--card-shadow); border-top:3px solid ${gcpAccent};`}>
    <div class="p-4 sm:p-5">
      <div class="flex items-center gap-1.5 mb-2 flex-wrap">
        {statuses.map(s => <span class="px-2 py-0.5 rounded-full text-[11px] font-medium" style={statusColors[s] || ''}>{s}</span>)}
        {date && <time class="text-[11px] ml-auto" style="color:var(--color-text-secondary);">{date}</time>}
      </div>
      <h3 class="text-sm sm:text-base font-medium mb-2 leading-snug" style="color:var(--color-text-primary);word-break:break-word;">{title}</h3>
      <p class="text-xs sm:text-sm leading-relaxed line-clamp-3" style="color:var(--color-text-secondary);">{content}</p>
      {hasDetails && (
        <div class="mt-3 pt-2 space-y-1 text-[11px]" style={`border-top:2px solid ${gcpAccent}20;`}>
          {target && <div><span class="font-medium" style={`color:${gcpAccent};`}>대상</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{target}</span></div>}
          {features && <div><span class="font-medium" style={`color:${gcpAccent};`}>기능</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{features}</span></div>}
          {regions && <div><span class="font-medium" style={`color:${gcpAccent};`}>리전</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{regions}</span></div>}
        </div>
      )}
    </div>
  </a>
) : (
  <!-- Azure Fluent: spacious, subtle, clean -->
  <a href={originalLink || '#'} target="_blank" rel="noopener noreferrer"
    class="azure-card block no-underline overflow-hidden transition-all duration-200"
    style="background:var(--color-surface); border:1px solid var(--color-border); border-radius:4px; box-shadow:var(--card-shadow);">
    <div class="p-5 sm:p-6">
      <div class="flex items-center gap-1.5 mb-3 flex-wrap">
        {statuses.map(s => <span class="px-2 py-0.5 rounded text-[11px] font-semibold" style={statusColors[s] || ''}>{s}</span>)}
        {date && <time class="text-[11px] ml-auto" style="color:var(--color-text-secondary);">{date}</time>}
      </div>
      <h3 class="text-sm sm:text-base font-semibold mb-3 leading-relaxed" style="color:var(--color-text-primary);word-break:break-word;">{title}</h3>
      <p class="text-xs sm:text-sm leading-loose line-clamp-3" style="color:var(--color-text-secondary);">{content}</p>
      {hasDetails && (
        <div class="mt-4 pt-3 space-y-2 text-xs" style="border-top:1px solid var(--color-border);">
          {target && <div><span class="font-semibold" style="color:#0078D4;">대상</span> <span class="ml-2" style="color:var(--color-text-secondary);" class="line-clamp-1">{target}</span></div>}
          {features && <div><span class="font-semibold" style="color:#0078D4;">기능</span> <span class="ml-2" style="color:var(--color-text-secondary);" class="line-clamp-1">{features}</span></div>}
          {regions && <div><span class="font-semibold" style="color:#0078D4;">리전</span> <span class="ml-2" style="color:var(--color-text-secondary);" class="line-clamp-1">{regions}</span></div>}
        </div>
      )}
    </div>
  </a>
)}

<style>
  .aws-card:hover { border-color: #879596 !important; border-left-color: #FF9900 !important; background: var(--color-bg) !important; }
  .gcp-card:hover { box-shadow: 0 2px 6px 2px rgba(60,64,67,0.15), 0 1px 2px rgba(60,64,67,0.30) !important; transform: translateY(-2px); }
  .azure-card:hover { border-color: #0078D4 !important; box-shadow: 0 0 2px rgba(0,0,0,0.12), 0 8px 16px rgba(0,0,0,0.14) !important; }
  .aws-card:hover .line-clamp-3,
  .gcp-card:hover .line-clamp-3,
  .azure-card:hover .line-clamp-3,
  .aws-card:hover .line-clamp-1,
  .gcp-card:hover .line-clamp-1,
  .azure-card:hover .line-clamp-1 {
    -webkit-line-clamp: unset !important;
  }
</style>

<script>
  // Mobile: first tap expands, second tap navigates
  if ('ontouchstart' in window) {
    document.querySelectorAll('.aws-card,.gcp-card,.azure-card').forEach(card => {
      let expanded = false;
      card.addEventListener('click', (e) => {
        if (!expanded) {
          e.preventDefault();
          card.querySelectorAll('.line-clamp-3,.line-clamp-1').forEach(el => {
            el.style.webkitLineClamp = 'unset';
          });
          expanded = true;
        }
        // second tap: default link behavior
      });
    });
  }
</script>
