---
interface Props {
  title: string; date: string; content: string; csp?: string;
  target?: string; features?: string; regions?: string; status?: string;
  originalLink?: string; index?: number; articleId?: number; isFallback?: boolean;
}

const { title, date, content, csp, target, features, regions, status, originalLink, index = 0, articleId, isFallback = false } = Astro.props;

let statuses: string[] = [];
try {
  if (status) { const p = JSON.parse(status); statuses = Array.isArray(p) ? p.filter((s: string) => !s.includes(':')) : [status]; }
} catch { statuses = status ? [status] : []; }

const statusColors: Record<string, string> = {
  '정식 출시': 'background:#dcfce7;color:#166534;',
  '미리보기': 'background:#dbeafe;color:#1e40af;',
  '베타': 'background:#f3e8ff;color:#6b21a8;',
  '지원 종료': 'background:#fee2e2;color:#991b1b;',
};

// GCP 4-color rotation
const gcpColors = ['#4285F4', '#EA4335', '#FBBC04', '#34A853'];
const gcpAccent = gcpColors[index % 4];

const hasDetails = !!(target || features || regions);

---

{csp === 'aws' ? (
  <!-- AWS Cloudscape: bordered, dense, severity left-border -->
  <a href={originalLink || '#'} target="_blank" rel="noopener noreferrer"
    id={`article-${Astro.props.articleId}`} class="aws-card block no-underline overflow-hidden transition-all duration-200"
    style="background:var(--color-surface); border:2px solid var(--color-border); border-radius:8px;">
    <div class="p-4 sm:p-5">
      <div class="flex items-center gap-1.5 mb-2 flex-wrap">
        {isFallback && (<span class="px-1.5 py-0.5 text-xs font-medium" style="border-radius:2px;background:#fef3c7;color:#92400e;">번역 준비중</span>)}
        {statuses.map(s => <span class="px-1.5 py-0.5 text-xs font-medium" style={`border-radius:2px;${statusColors[s] || ''}`}>{s}</span>)}
        {date && <time class="text-xs ml-auto" style="color:var(--color-text-secondary);">{date}</time>}
      </div>
      <h3 class="text-base sm:text-lg font-bold mb-2 leading-snug" style="color:var(--color-text-primary);word-break:break-word;">{title}</h3>
      <p class="text-sm leading-relaxed line-clamp-3" style="color:var(--color-text-secondary);">{content}</p>
      {hasDetails && (
        <div class="mt-3 pt-2 space-y-1 text-xs" style="border-top:1px solid var(--color-border);">
          {target && <div><span class="font-semibold" style="color:#0972D3;"><svg class="inline w-3 h-3 mr-0.5" viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="4" r="2.5"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>대상</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{target}</span></div>}
          {features && <div><span class="font-semibold" style="color:#0972D3;"><svg class="inline w-3 h-3 mr-0.5" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l2 4h4l-3 3 1 4-4-2-4 2 1-4-3-3h4z"/></svg>기능</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{features}</span></div>}
          {regions && <div><span class="font-semibold" style="color:#0972D3;"><svg class="inline w-3 h-3 mr-0.5" viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="1" fill="none"/><ellipse cx="8" cy="8" rx="3" ry="6" fill="none" stroke="currentColor" stroke-width="1"/></svg>리전</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{regions}</span></div>}
        </div>
      )}
    </div>
  </a>
) : csp === 'gcp' ? (
  <!-- GCP Material 3: rounded, floating, surface-tint + 4-color top border -->
  <a href={originalLink || '#'} target="_blank" rel="noopener noreferrer"
    id={`article-${Astro.props.articleId}`} class="gcp-card block no-underline overflow-hidden transition-all duration-200"
    style={`background:var(--color-surface); border-radius:12px; box-shadow:var(--card-shadow); border-top:3px solid ${gcpAccent}; --gcp-accent:${gcpAccent};`}>
    <div class="p-4 sm:p-5">
      <div class="flex items-center gap-1.5 mb-2 flex-wrap">
        {isFallback && (<span class="px-1.5 py-0.5 rounded text-xs font-medium" style="background:#fef3c7;color:#92400e;">번역 준비중</span>)}
        {statuses.map(s => <span class="px-2 py-0.5 rounded-full text-xs font-medium" style={statusColors[s] || ''}>{s}</span>)}
        {date && <time class="text-xs ml-auto" style="color:var(--color-text-secondary);">{date}</time>}
      </div>
      <h3 class="text-base sm:text-lg font-bold mb-2 leading-snug" style="color:var(--color-text-primary);word-break:break-word;">{title}</h3>
      <p class="text-sm leading-relaxed line-clamp-3" style="color:var(--color-text-secondary);">{content}</p>
      {hasDetails && (
        <div class="mt-3 pt-2 space-y-1 text-xs" style={`border-top:1px solid ${gcpAccent}1F;`}>
          {target && <div><span class="font-medium" style={`color:${gcpAccent};`}><svg class="inline w-3 h-3 mr-0.5" viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="4" r="2.5"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>대상</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{target}</span></div>}
          {features && <div><span class="font-medium" style={`color:${gcpAccent};`}><svg class="inline w-3 h-3 mr-0.5" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l2 4h4l-3 3 1 4-4-2-4 2 1-4-3-3h4z"/></svg>기능</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{features}</span></div>}
          {regions && <div><span class="font-medium" style={`color:${gcpAccent};`}><svg class="inline w-3 h-3 mr-0.5" viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="1" fill="none"/><ellipse cx="8" cy="8" rx="3" ry="6" fill="none" stroke="currentColor" stroke-width="1"/></svg>리전</span>&nbsp;&nbsp;<span style="color:var(--color-text-secondary);" class="line-clamp-1">{regions}</span></div>}
        </div>
      )}
    </div>
  </a>
) : (
  <!-- Azure Fluent 2: spacious, shadow depth, left accent -->
  <a href={originalLink || '#'} target="_blank" rel="noopener noreferrer"
    id={`article-${Astro.props.articleId}`} class="azure-card block no-underline overflow-hidden transition-all duration-200"
    style="background:var(--color-surface); border:1px solid var(--color-border); border-left:3px solid #0078D4; border-radius:4px; box-shadow:var(--card-shadow);">
    <div class="p-4 sm:p-5">
      <div class="flex items-center gap-1.5 mb-3 flex-wrap">
        {isFallback && (<span class="px-1.5 py-0.5 rounded text-xs font-medium" style="background:#fef3c7;color:#92400e;">번역 준비중</span>)}
        {statuses.map(s => <span class="px-2 py-0.5 rounded text-xs font-semibold" style={statusColors[s] || ''}>{s}</span>)}
        {date && <time class="text-xs ml-auto" style="color:var(--color-text-secondary);">{date}</time>}
      </div>
      <h3 class="text-base sm:text-lg font-semibold mb-2 leading-snug" style="color:var(--color-text-primary);word-break:break-word;">{title}</h3>
      <p class="text-sm leading-relaxed line-clamp-3" style="color:var(--color-text-secondary);">{content}</p>
      {hasDetails && (
        <div class="mt-3 pt-2 space-y-1 text-xs" style="border-top:1px solid var(--color-border);">
          {target && <div><span class="font-semibold" style="color:#0078D4;"><svg class="inline w-3 h-3 mr-0.5" viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="4" r="2.5"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>대상</span> <span class="ml-2" style="color:var(--color-text-secondary);" class="line-clamp-1">{target}</span></div>}
          {features && <div><span class="font-semibold" style="color:#0078D4;"><svg class="inline w-3 h-3 mr-0.5" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l2 4h4l-3 3 1 4-4-2-4 2 1-4-3-3h4z"/></svg>기능</span> <span class="ml-2" style="color:var(--color-text-secondary);" class="line-clamp-1">{features}</span></div>}
          {regions && <div><span class="font-semibold" style="color:#0078D4;"><svg class="inline w-3 h-3 mr-0.5" viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="1" fill="none"/><ellipse cx="8" cy="8" rx="3" ry="6" fill="none" stroke="currentColor" stroke-width="1"/></svg>리전</span> <span class="ml-2" style="color:var(--color-text-secondary);" class="line-clamp-1">{regions}</span></div>}
        </div>
      )}
    </div>
  </a>
)}

<style>
  .aws-card:hover,   .aws-card.card-active   { border-color: #879596 !important; background: color-mix(in srgb, #0972D3 6%, var(--color-surface)) !important; }
  .gcp-card:hover,   .gcp-card.card-active   { box-shadow: 0 2px 6px 2px rgba(60,64,67,0.15), 0 1px 2px rgba(60,64,67,0.30) !important; transform: translateY(-2px); background: color-mix(in srgb, var(--gcp-accent) 4%, var(--color-surface)) !important; }
  .azure-card:hover, .azure-card.card-active { border-color: #0078D4 !important; border-left-color: #0078D4 !important; box-shadow: 0 0 2px rgba(0,0,0,0.12), 0 8px 16px rgba(0,0,0,0.14) !important; }

  .aws-card:hover .line-clamp-3,         .aws-card:hover .line-clamp-1,
  .gcp-card:hover .line-clamp-3,         .gcp-card:hover .line-clamp-1,
  .azure-card:hover .line-clamp-3,       .azure-card:hover .line-clamp-1,
  .aws-card.card-active .line-clamp-3,   .aws-card.card-active .line-clamp-1,
  .gcp-card.card-active .line-clamp-3,   .gcp-card.card-active .line-clamp-1,
  .azure-card.card-active .line-clamp-3, .azure-card.card-active .line-clamp-1 {
    -webkit-line-clamp: unset !important;
  }

  /* Hash anchor pulse — amber glow, fades after 2s */
  @keyframes card-pulse {
    0%   { outline: 3px solid #FBBF24; outline-offset: 3px; }
    65%  { outline: 3px solid #FBBF24; outline-offset: 3px; }
    100% { outline: 3px solid transparent; outline-offset: 3px; }
  }
  .card-pulse { animation: card-pulse 2s ease-out forwards; }
</style>

<script>
  // Mobile: first tap expands, second tap navigates
  if ('ontouchstart' in window) {
    document.querySelectorAll<HTMLAnchorElement>('.aws-card,.gcp-card,.azure-card').forEach((card) => {
      let expanded = false;
      card.addEventListener('click', (e) => {
        if (!expanded) {
          e.preventDefault();
          card.querySelectorAll<HTMLElement>('.line-clamp-3,.line-clamp-1').forEach((el) => {
            el.style.webkitLineClamp = 'unset';
          });
          expanded = true;
        }
        // second tap: default link behavior
      });
    });
  }
</script>
