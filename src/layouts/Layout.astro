---
import '../styles/base.css';
import '../styles/themes.css';

interface Props {
  title: string;
  vendor?: string;
}

const { title, vendor = 'home' } = Astro.props;
const cspNames: Record<string, string> = { home: 'Cloud What\'s New', aws: 'AWS', gcp: 'GCP', azure: 'Azure' };
---

<!DOCTYPE html>
<html lang="ko" data-vendor={vendor}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@100..900&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body style="background-color: var(--color-bg); color: var(--color-text-primary);" class="transition-colors duration-200">
    <header style="background-color: var(--color-surface); border-bottom: 1px solid var(--color-border);">
      <div class="max-w-7xl mx-auto py-4 px-4 sm:px-6 lg:px-8 flex justify-between items-center">
        <a href="/" class="text-xl font-bold" style="color: var(--color-text-primary);">
          ☁️ Cloud What's New
        </a>

        <nav class="flex items-center gap-1">
          {['aws', 'gcp', 'azure'].map(c => {
            const colors: Record<string, string> = { aws: '#FF9900', gcp: '#34A853', azure: '#0078D4' };
            const isActive = vendor === c;
            return (
              <a href={`/${c}`}
                class="px-3 py-1.5 rounded-full text-sm font-medium transition-colors"
                style={isActive
                  ? `background-color: ${colors[c]}; color: white;`
                  : `color: var(--color-text-secondary); border: 1px solid var(--color-border);`}>
                {cspNames[c]}
              </a>
            );
          })}
          <button id="theme-toggle" class="ml-3 p-2 rounded-lg transition-colors" style="color: var(--color-text-secondary);">
            <svg id="icon-dark" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
            </svg>
            <svg id="icon-light" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
      <slot />
    </main>

    <footer style="background-color: var(--color-surface); border-top: 1px solid var(--color-border);" class="mt-8">
      <div class="max-w-7xl mx-auto py-4 px-4 sm:px-6 lg:px-8">
        <p class="text-center text-sm" style="color: var(--color-text-secondary);">
          © {new Date().getFullYear()} Cloud What's New. Not affiliated with AWS, Google Cloud, or Microsoft Azure.
        </p>
      </div>
    </footer>

    <script is:inline>
      (function() {
        const html = document.documentElement;
        const isDark = localStorage.getItem('theme') === 'dark' ||
          (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches);
        if (isDark) html.setAttribute('data-theme', 'dark');

        const iconDark = document.getElementById('icon-dark');
        const iconLight = document.getElementById('icon-light');
        function updateIcons() {
          const dark = html.hasAttribute('data-theme');
          iconDark.classList.toggle('hidden', dark);
          iconLight.classList.toggle('hidden', !dark);
        }
        updateIcons();

        document.getElementById('theme-toggle').addEventListener('click', () => {
          if (html.hasAttribute('data-theme')) {
            html.removeAttribute('data-theme');
            localStorage.setItem('theme', 'light');
          } else {
            html.setAttribute('data-theme', 'dark');
            localStorage.setItem('theme', 'dark');
          }
          updateIcons();
        });
      })();
    </script>
  </body>
</html>
