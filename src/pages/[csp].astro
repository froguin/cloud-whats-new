---
import Layout from '../layouts/Layout.astro';
import UpdateCardCloudscape from '../components/UpdateCardCloudscape.astro';

const { csp } = Astro.params;
const valid = ['aws', 'gcp', 'azure'];
if (!csp || !valid.includes(csp)) return Astro.redirect('/');

const API_BASE = 'https://api.whats-new.kr';

let articles: any[] = [];
try {
  const res = await fetch(`${API_BASE}/api/articles?csp=${csp}&lang=ko&limit=500`);
  articles = (await res.json()).items || [];
} catch (e) { console.error(e); }

const rssLinks: Record<string, { name: string; url: string }> = {
  aws: { name: 'AWS What\'s New', url: 'https://aws.amazon.com/new/' },
  gcp: { name: 'Google Cloud Release Notes', url: 'https://cloud.google.com/release-notes' },
  azure: { name: 'Azure Updates', url: 'https://azure.microsoft.com/en-us/updates/' },
};
const names: Record<string, string> = { aws: 'Amazon Web Services', gcp: 'Google Cloud', azure: 'Microsoft Azure' };
const rss = rssLinks[csp];
const latest = articles[0]?.pub_date ? new Date(articles[0].pub_date).toLocaleString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '';

// Status counting
const STATUS_ORDER = ['정식 출시', '미리보기', '베타', '지원 종료'];
const statusCounts: Record<string, number> = {};
for (const a of articles) {
  if (a.is_fallback) {
    statusCounts['번역 준비중'] = (statusCounts['번역 준비중'] || 0) + 1;
  } else {
    try {
      const ss = JSON.parse(a.status || '[]');
      const arr: string[] = Array.isArray(ss) ? ss : [];
      for (const s of arr) {
        if (STATUS_ORDER.includes(s)) statusCounts[s] = (statusCounts[s] || 0) + 1;
      }
    } catch { /* ignore */ }
  }
}

function getArticleStatuses(a: any): string {
  if (a.is_fallback) return '번역 준비중';
  try {
    const ss = JSON.parse(a.status || '[]');
    return Array.isArray(ss) ? ss.join(',') : '';
  } catch { return ''; }
}

const activeStatusFilters = [...STATUS_ORDER.filter(s => (statusCounts[s] || 0) > 0), ...(statusCounts['번역 준비중'] ? ['번역 준비중'] : [])];
---

<Layout title={`${csp.toUpperCase()} What's New`} vendor={csp}>
  <div class="mb-4 p-4 rounded-lg flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3"
    style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius);">
    <div class="flex flex-col gap-1">
      <p class="text-xs sm:text-sm" style="color: var(--color-text-secondary);">
        {names[csp]} <a href={rss.url} target="_blank" rel="noopener noreferrer" class="underline font-medium" style="color: var(--color-primary);">공식 소식</a>을 한국어로 요약합니다.
      </p>
      {latest && (
        <span class="text-[11px]" style="color: var(--color-text-secondary);">
          최종 업데이트: {latest}
        </span>
      )}
    </div>
    <div class="flex flex-col gap-2 items-stretch sm:items-end shrink-0">
      {activeStatusFilters.length > 0 && (
        <div class="flex flex-wrap gap-1.5" id="filter-bar">
          {activeStatusFilters.map(s => (
            <button
              class="filter-btn text-xs px-2.5 py-1 rounded-full font-medium border transition-colors"
              data-filter={s}
              style="border-color: var(--color-border); color: var(--color-text-secondary); background: var(--color-surface); cursor: pointer;">
              {s}<span class="ml-1 opacity-60 filter-count">{statusCounts[s]}</span>
            </button>
          ))}
        </div>
      )}
      <input type="text" id="search" placeholder="검색..."
        class="w-full sm:w-72 px-4 py-2 text-sm rounded outline-none transition-colors"
        style="border: 2px solid var(--color-border); background: var(--color-surface); box-shadow: inset 0 2px 4px rgba(0,0,0,0.15); color: var(--color-text-primary); border-radius: var(--radius);" />
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 items-start" id="cards">
    {articles.map((a, i) => (
      <div class="card-wrapper" data-statuses={getArticleStatuses(a)}>
        <UpdateCardCloudscape
          title={a.title} csp={a.csp} index={i}
          date={a.pub_date ? new Date(a.pub_date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' }) : ''}
          content={a.summary || ''} target={a.target} features={a.features}
          regions={a.regions} status={a.status} originalLink={a.url} isFallback={!!a.is_fallback} originalTitle={a.original_title} articleId={a.article_id} />
      </div>
    ))}
  </div>

  {articles.length === 0 && (
    <p class="text-center py-16 text-sm" style="color: var(--color-text-secondary);">업데이트가 없습니다.</p>
  )}

  <p id="no-results" class="hidden text-center py-16 text-sm" style="color: var(--color-text-secondary);">검색 결과가 없습니다.</p>

  <script>
    const searchEl = document.getElementById('search') as HTMLInputElement;
    const wrappers = Array.from(document.querySelectorAll<HTMLElement>('#cards > .card-wrapper'));
    const noResults = document.getElementById('no-results') as HTMLElement;
    let activeFilter = '';

    function applyFilters() {
      const q = (searchEl?.value || '').toLowerCase();
      let visible = 0;
      wrappers.forEach(wrapper => {
        const matchSearch = !q || (wrapper.textContent?.toLowerCase() || '').includes(q);
        const matchFilter = !activeFilter || (wrapper.dataset.statuses || '').includes(activeFilter);
        const show = matchSearch && matchFilter;
        wrapper.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    }

    searchEl?.addEventListener('input', applyFilters);

    document.querySelectorAll<HTMLElement>('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const f = btn.dataset.filter || '';
        activeFilter = activeFilter === f ? '' : f;
        document.querySelectorAll<HTMLElement>('.filter-btn').forEach(b => {
          const on = b.dataset.filter === activeFilter && activeFilter !== '';
          b.style.borderColor = on ? 'var(--color-primary)' : 'var(--color-border)';
          b.style.color = on ? 'var(--color-primary)' : 'var(--color-text-secondary)';
          b.style.background = on ? 'color-mix(in srgb, var(--color-primary) 12%, transparent)' : 'var(--color-surface)';
          b.style.fontWeight = on ? '700' : '';
        });
        applyFilters();
      });
    });
  </script>
</Layout>

<script>
  // Auto-expand card when navigated via hash anchor
  let activeCard: HTMLElement | null = null;
  function expandTarget() {
    const hash = window.location.hash;
    if (!hash) return;
    if (activeCard) {
      activeCard.classList.remove('card-active');
      activeCard.style.outline = '';
      activeCard.style.outlineOffset = '';
      activeCard.querySelectorAll('.line-clamp-3,.line-clamp-1').forEach(el => {
        (el as HTMLElement).style.webkitLineClamp = '';
      });
    }
    const card = document.querySelector(hash) as HTMLElement | null;
    if (!card) return;
    activeCard = card;
    card.querySelectorAll('.line-clamp-3,.line-clamp-1').forEach(el => {
      (el as HTMLElement).style.webkitLineClamp = 'unset';
    });
    card.classList.add('card-active');
    const topBorder = card.style.borderTopColor || getComputedStyle(card).borderTopColor;
    const outlineColor = topBorder && topBorder !== 'rgba(0, 0, 0, 0)' ? topBorder : 'var(--color-primary)';
    card.style.outline = '3px solid ' + outlineColor;
    card.style.outlineOffset = '2px';
    setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'center' }), 100);
  }
  document.addEventListener('click', (e) => {
    if (activeCard && !activeCard.contains(e.target as Node)) {
      activeCard.classList.remove('card-active');
      activeCard.style.outline = '';
      activeCard.style.outlineOffset = '';
      activeCard.querySelectorAll('.line-clamp-3,.line-clamp-1').forEach(el => {
        (el as HTMLElement).style.webkitLineClamp = '';
      });
      activeCard = null;
    }
  });
  expandTarget();
  window.addEventListener('hashchange', expandTarget);
</script>
