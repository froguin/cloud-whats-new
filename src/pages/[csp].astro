---
import Layout from '../layouts/Layout.astro';
import UpdateCardCloudscape from '../components/UpdateCardCloudscape.astro';

const { csp } = Astro.params;
const valid = ['aws', 'gcp', 'azure'];
if (!csp || !valid.includes(csp)) return Astro.redirect('/');

const API_BASE = 'https://api.whats-new.kr';

let articles: any[] = [];
try {
  const res = await fetch(`${API_BASE}/api/articles?csp=${csp}&lang=ko&limit=500`);
  articles = (await res.json()).items || [];
} catch (e) { console.error(e); }

const rssLinks: Record<string, { name: string; url: string }> = {
  aws: { name: 'AWS What\'s New', url: 'https://aws.amazon.com/new/' },
  gcp: { name: 'Google Cloud Release Notes', url: 'https://cloud.google.com/release-notes' },
  azure: { name: 'Azure Updates', url: 'https://azure.microsoft.com/en-us/updates/' },
};
const names: Record<string, string> = { aws: 'Amazon Web Services', gcp: 'Google Cloud', azure: 'Microsoft Azure' };
const rss = rssLinks[csp];
const latest = articles[0]?.pub_date ? new Date(articles[0].pub_date).toLocaleString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '';

// Status counting
const STATUS_ORDER = ['정식 출시', '미리보기', '베타', '지원 종료'];
const statusCounts: Record<string, number> = {};
for (const a of articles) {
  if (a.is_fallback) {
    statusCounts['번역 준비중'] = (statusCounts['번역 준비중'] || 0) + 1;
  } else {
    try {
      const ss = JSON.parse(a.status || '[]');
      const arr: string[] = Array.isArray(ss) ? ss : [];
      for (const s of arr) {
        if (STATUS_ORDER.includes(s)) statusCounts[s] = (statusCounts[s] || 0) + 1;
      }
    } catch { /* ignore */ }
  }
}

function getArticleStatuses(a: any): string {
  if (a.is_fallback) return '번역 준비중';
  try {
    const ss = JSON.parse(a.status || '[]');
    return Array.isArray(ss) ? ss.join(',') : '';
  } catch { return ''; }
}

const activeStatusFilters = [...STATUS_ORDER.filter(s => (statusCounts[s] || 0) > 0), ...(statusCounts['번역 준비중'] ? ['번역 준비중'] : [])];

---

<Layout
  title={`${csp.toUpperCase()} What's New`}
  description={`${names[csp]} 공식 업데이트를 한국어로 요약한 최신 릴리스 노트 목록입니다.`}
  vendor={csp}
>
  <div class="mb-4 p-4 rounded-lg flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3"
    style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius);">
    <div class="flex flex-col gap-1">
      <p class="text-xs sm:text-sm" style="color: var(--color-text-secondary);">
        {names[csp]} <a href={rss.url} target="_blank" rel="noopener noreferrer" class="underline font-medium" style="color: var(--color-primary);">공식 소식</a>을 한국어로 요약합니다.
      </p>
      {latest && (
        <span class="text-[11px]" style="color: var(--color-text-secondary);">
          최종 업데이트: {latest}
        </span>
      )}
    </div>
    <div class="flex flex-col sm:flex-row sm:items-center gap-2 shrink-0">
      {activeStatusFilters.length > 0 && (
        <div class="flex flex-wrap gap-1.5" id="filter-bar">
          {activeStatusFilters.map(s => (
            <button
              class="filter-btn text-xs px-2.5 py-1 rounded-full font-medium border transition-all"
              data-filter={s}>
              {s}<span class="ml-1 opacity-60">{statusCounts[s]}</span>
            </button>
          ))}
        </div>
      )}
      <input type="text" id="search" placeholder="검색..."
        class="w-full sm:w-56 px-4 py-2 text-sm rounded outline-none transition-colors"
        style="border: 2px solid var(--color-border); background: var(--color-surface); box-shadow: inset 0 2px 4px rgba(0,0,0,0.15); color: var(--color-text-primary); border-radius: var(--radius);" />
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 items-start" id="cards">
    {articles.map((a, i) => (
      <div class="card-wrapper" data-statuses={getArticleStatuses(a)}>
        <UpdateCardCloudscape
          title={a.title} csp={a.csp} index={i}
          date={a.pub_date ? new Date(a.pub_date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' }) : ''}
          content={a.summary || ''} target={a.target} features={a.features}
          regions={a.regions} status={a.status} originalLink={a.url} isFallback={!!a.is_fallback} articleId={a.article_id} />
      </div>
    ))}
  </div>

  {articles.length === 0 && (
    <p class="text-center py-16 text-sm" style="color: var(--color-text-secondary);">업데이트가 없습니다.</p>
  )}

  <p id="no-results" class="hidden text-center py-16 text-sm" style="color: var(--color-text-secondary);">검색 결과가 없습니다.</p>

  <script>
    const searchEl = document.getElementById('search') as HTMLInputElement;
    const wrappers = Array.from(document.querySelectorAll<HTMLElement>('#cards > .card-wrapper'));
    const noResults = document.getElementById('no-results') as HTMLElement;
    let activeFilter = '';

    function applyFilters() {
      const q = (searchEl?.value || '').toLowerCase();
      let visible = 0;
      wrappers.forEach(wrapper => {
        const matchSearch = !q || (wrapper.textContent?.toLowerCase() || '').includes(q);
        const matchFilter = !activeFilter || (wrapper.dataset.statuses || '').includes(activeFilter);
        const show = matchSearch && matchFilter;
        wrapper.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    }

    searchEl?.addEventListener('input', applyFilters);

    document.querySelectorAll<HTMLElement>('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const f = btn.dataset.filter || '';
        activeFilter = activeFilter === f ? '' : f;
        document.querySelectorAll<HTMLElement>('.filter-btn').forEach(b => {
          b.classList.toggle('is-active', b.dataset.filter === activeFilter && activeFilter !== '');
        });
        applyFilters();
      });
    });
  </script>

  <style>
    /* ── 비활성: 글씨+테두리만, 배경 투명 ── */
    .filter-btn[data-filter="정식 출시"]  { border-color:#16a34a; color:#166534; background:transparent; }
    .filter-btn[data-filter="미리보기"]   { border-color:#3b82f6; color:#1e40af; background:transparent; }
    .filter-btn[data-filter="베타"]       { border-color:#a855f7; color:#6b21a8; background:transparent; }
    .filter-btn[data-filter="지원 종료"]  { border-color:#ef4444; color:#991b1b; background:transparent; }
    .filter-btn[data-filter="번역 준비중"]{ border-color:#f59e0b; color:#92400e; background:transparent; }

    /* ── 다크모드 비활성: 채도 높인 밝은 색 ── */
    :global([data-theme="dark"]) .filter-btn[data-filter="정식 출시"]  { border-color:#4ade80; color:#4ade80; }
    :global([data-theme="dark"]) .filter-btn[data-filter="미리보기"]   { border-color:#60a5fa; color:#60a5fa; }
    :global([data-theme="dark"]) .filter-btn[data-filter="베타"]       { border-color:#c084fc; color:#c084fc; }
    :global([data-theme="dark"]) .filter-btn[data-filter="지원 종료"]  { border-color:#f87171; color:#f87171; }
    :global([data-theme="dark"]) .filter-btn[data-filter="번역 준비중"]{ border-color:#fbbf24; color:#fbbf24; }

    /* ── 활성: 배경색 채움 ── */
    .filter-btn.is-active[data-filter="정식 출시"]  { background:#dcfce7; color:#166534; border-color:#16a34a; font-weight:700; box-shadow:0 0 0 2px #16a34a; }
    .filter-btn.is-active[data-filter="미리보기"]   { background:#dbeafe; color:#1e40af; border-color:#3b82f6; font-weight:700; box-shadow:0 0 0 2px #3b82f6; }
    .filter-btn.is-active[data-filter="베타"]       { background:#f3e8ff; color:#6b21a8; border-color:#a855f7; font-weight:700; box-shadow:0 0 0 2px #a855f7; }
    .filter-btn.is-active[data-filter="지원 종료"]  { background:#fee2e2; color:#991b1b; border-color:#ef4444; font-weight:700; box-shadow:0 0 0 2px #ef4444; }
    .filter-btn.is-active[data-filter="번역 준비중"]{ background:#fef3c7; color:#92400e; border-color:#f59e0b; font-weight:700; box-shadow:0 0 0 2px #f59e0b; }

    /* ── 다크모드 활성: 진한 배경 + 밝은 글씨 ── */
    :global([data-theme="dark"]) .filter-btn.is-active[data-filter="정식 출시"]  { background:#166534; color:#dcfce7; border-color:#4ade80; box-shadow:0 0 0 2px #4ade80; }
    :global([data-theme="dark"]) .filter-btn.is-active[data-filter="미리보기"]   { background:#1e3a8a; color:#dbeafe; border-color:#60a5fa; box-shadow:0 0 0 2px #60a5fa; }
    :global([data-theme="dark"]) .filter-btn.is-active[data-filter="베타"]       { background:#581c87; color:#f3e8ff; border-color:#c084fc; box-shadow:0 0 0 2px #c084fc; }
    :global([data-theme="dark"]) .filter-btn.is-active[data-filter="지원 종료"]  { background:#7f1d1d; color:#fee2e2; border-color:#f87171; box-shadow:0 0 0 2px #f87171; }
    :global([data-theme="dark"]) .filter-btn.is-active[data-filter="번역 준비중"]{ background:#78350f; color:#fef3c7; border-color:#fbbf24; box-shadow:0 0 0 2px #fbbf24; }
  </style>
</Layout>

<script>
  // Pulse on arrival + persistent card-active (hover-like) state
  let activeCard: HTMLElement | null = null;

  function expandTarget() {
    const hash = window.location.hash;
    if (!hash) return;

    // Deactivate previous
    if (activeCard) activeCard.classList.remove('card-active');

    const card = document.querySelector<HTMLElement>(hash);
    if (!card) return;
    activeCard = card;

    // Persist hover-like state
    card.classList.add('card-active');

    // Amber pulse for initial attention
    card.classList.remove('card-pulse');
    void card.offsetWidth;
    card.classList.add('card-pulse');

    setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'center' }), 100);
  }

  // Click outside to dismiss active state
  document.addEventListener('click', (e) => {
    if (activeCard && !activeCard.contains(e.target as Node)) {
      activeCard.classList.remove('card-active');
      activeCard = null;
    }
  });

  expandTarget();
  window.addEventListener('hashchange', expandTarget);
</script>
