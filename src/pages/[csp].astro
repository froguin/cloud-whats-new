---
import Layout from '../layouts/Layout.astro';
import UpdateCardCloudscape from '../components/UpdateCardCloudscape.astro';

const { csp } = Astro.params;
const valid = ['aws', 'gcp', 'azure'];
if (!csp || !valid.includes(csp)) return Astro.redirect('/');

const API_BASE = import.meta.env.WORKER_URL || 'https://WORKER_URL_REDACTED';

let articles: any[] = [];
try {
  const res = await fetch(`${API_BASE}/api/articles?csp=${csp}&lang=ko&limit=50`);
  articles = (await res.json()).items || [];
} catch (e) { console.error(e); }
const latest = articles[0]?.pub_date ? new Date(articles[0].pub_date).toLocaleString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '';
---

<Layout title={`${csp.toUpperCase()} What's New`} vendor={csp}>
  <div class="flex items-center justify-between mb-6 max-w-lg mx-auto sm:max-w-none">
    <input type="text" id="search" placeholder="검색..."
      class="flex-1 px-4 py-2 text-sm rounded-lg outline-none transition-colors"
      style="border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-primary);" />
    {latest && (
      <span class="text-[11px] ml-3 shrink-0 hidden sm:inline" style="color: var(--color-text-secondary);">
        최종 업데이트: {latest}
      </span>
    )}
  </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 items-start" id="cards">
    {articles.map((a, i) => (
      <UpdateCardCloudscape
        title={a.title} csp={a.csp} index={i}
        date={a.pub_date ? new Date(a.pub_date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' }) : ''}
        content={a.summary || ''} target={a.target} features={a.features}
        regions={a.regions} status={a.status} originalLink={a.url} />
    ))}
  </div>

  {articles.length === 0 && (
    <p class="text-center py-16 text-sm" style="color: var(--color-text-secondary);">업데이트가 없습니다.</p>
  )}

  <script>
    const s = document.getElementById('search') as HTMLInputElement;
    const c = document.querySelectorAll('#cards > a');
    s?.addEventListener('input', () => {
      const q = s.value.toLowerCase();
      c.forEach(el => { (el as HTMLElement).style.display = (el.textContent?.toLowerCase() || '').includes(q) ? '' : 'none'; });
    });
  </script>
</Layout>
