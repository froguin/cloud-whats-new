---
import Layout from '../layouts/Layout.astro';
import UpdateCard from '../components/UpdateCard.astro';

interface Update {
  title: string;
  date: string;
  content: string;
  target?: string;
  features?: string;
  regions?: string;
  status?: string;
  originalLink?: string;
}

let updates: Update[] = [];
let errorMessage: string | null = null;
let lastUpdated: string | null = null;

try {
  const baseUrl = Astro.url.origin;
  const response = await fetch(`${baseUrl}/.netlify/functions/fetch-updates`, {
    method: 'GET',
    headers: {
      'Accept': 'application/json',
    },
  });
  
  if (!response.ok) {
    throw new Error(`HTTP error! status: ${response.status}`);
  }
  
  updates = await response.json();
  lastUpdated = new Date().toLocaleString('ko-KR');
} catch (e) {
  console.error('데이터를 가져오는 중 오류가 발생했습니다:', e);
  errorMessage = e instanceof Error ? e.message : '알 수 없는 오류가 발생했습니다';
}
---

<Layout title="AWS What's New 한국어 요약">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {lastUpdated && (
      <div class="text-sm text-gray-500 mb-4">
        마지막 업데이트: {lastUpdated}
      </div>
    )}
    {errorMessage ? (
      <div class="rounded-md bg-red-50 p-4 my-4">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">오류 발생</h3>
            <div class="mt-2 text-sm text-red-700">
              <p>데이터를 불러오는 중 오류가 발생했습니다: {errorMessage}</p>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 my-6">
        {updates.length > 0 ? (
          updates.map((update) => (
            <UpdateCard {...update} />
          ))
        ) : (
          <div class="col-span-full text-center py-12">
            <p class="text-gray-500">현재 표시할 업데이트가 없습니다.</p>
          </div>
        )}
      </div>
    )}
  </div>
</Layout>
