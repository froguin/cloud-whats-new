---
import Layout from '../layouts/Layout.astro';
import UpdateCard from '../components/UpdateCard.astro';

interface Update {
  title: string;
  date: string;
  content: string;
  target?: string;
  features?: string;
  regions?: string;
  status?: string;
  originalLink?: string;
}

interface Meta {
  isCached: boolean;
  lastUpdated: string;
  itemCount: number;
}

let updates: Update[] = [];
let meta: Meta | null = null;
let errorMessage: string | null = null;

try {
  const baseUrl = Astro.url.origin;
  const response = await fetch(`${baseUrl}/.netlify/functions/fetch-updates`, {
    method: 'GET',
    headers: {
      'Accept': 'application/json',
    },
  });
  
  if (!response.ok) {
    throw new Error(`HTTP error! status: ${response.status}`);
  }
  
  const data = await response.json();
  updates = data.items;
  meta = data.meta;
} catch (e) {
  console.error('데이터를 가져오는 중 오류가 발생했습니다:', e);
  errorMessage = e instanceof Error ? e.message : '알 수 없는 오류가 발생했습니다';
}
---

<Layout title="AWS What's New 한국어 요약">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {meta && (
      <div class="text-sm text-gray-500 mb-4">
        <div class="flex justify-between items-center">
          <div>
            마지막 업데이트: {new Date(meta.lastUpdated).toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' })}
            {meta.isCached && <span class="ml-2 text-blue-600">(캐시됨)</span>}
          </div>
          <div>
            총 {meta.itemCount}개의 업데이트
          </div>
        </div>
      </div>
    )}

    {/* 검색 입력란 추가 */}
    <div class="mb-6">
      <input 
        type="text" 
        id="search-input" 
        placeholder="업데이트 검색..." 
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
    </div>

    {errorMessage ? (
      <div class="rounded-md bg-red-50 p-4 my-4">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">오류 발생</h3>
            <div class="mt-2 text-sm text-red-700">
              <p>데이터를 불러오는 중 오류가 발생했습니다: {errorMessage}</p>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div id="updates-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 my-6">
        {updates.length > 0 ? (
          updates.map((update) => (
            <UpdateCard {...update} />
          ))
        ) : (
          <div class="col-span-full text-center py-12">
            <p class="text-gray-500">현재 표시할 업데이트가 없습니다.</p>
          </div>
        )}
      </div>
    )}
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('search-input');
      const updatesGrid = document.getElementById('updates-grid');
      const updateCards = updatesGrid?.querySelectorAll('update-card');

      searchInput?.addEventListener('input', (e) => {
        const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
        
        updateCards?.forEach((card) => {
          const cardContent = card.textContent?.toLowerCase() || '';
          
          if (cardContent.includes(searchTerm)) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });

        // 검색 결과가 없을 때 메시지 표시
        const visibleCards = updatesGrid?.querySelectorAll('update-card:not(.hidden)');
        const noResultsMessage = updatesGrid?.querySelector('.no-results-message');

        if (visibleCards?.length === 0) {
          if (!noResultsMessage) {
            const message = document.createElement('div');
            message.classList.add('col-span-full', 'text-center', 'py-12', 'no-results-message');
            message.innerHTML = `<p class="text-gray-500">검색 결과가 없습니다.</p>`;
            updatesGrid?.appendChild(message);
          }
        } else {
          noResultsMessage?.remove();
        }
      });
    });
  </script>
</Layout>