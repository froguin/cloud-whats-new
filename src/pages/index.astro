---
import Layout from '../layouts/Layout.astro';

const API_BASE = 'https://api.whats-new.kr';

const csps = [
  { id: 'aws', name: 'Amazon Web Services', color: '#FF9900', accent: '#232F3E', font: "'Amazon Ember', sans-serif" },
  { id: 'gcp', name: 'Google Cloud', color: 'linear-gradient(to right, #4285F4 25%, #EA4335 25%, #EA4335 50%, #FBBC04 50%, #FBBC04 75%, #34A853 75%)', accent: '#4285F4', isGradient: true, font: "'Google Sans', sans-serif", weight: 700 },
  { id: 'azure', name: 'Microsoft Azure', color: '#0078D4', accent: '#50E6FF', font: "'Segoe UI Web', 'Segoe UI', sans-serif" },
];

const data: Record<string, any[]> = {};
for (const c of csps) {
  try {
    const res = await fetch(`${API_BASE}/api/articles?csp=${c.id}&lang=ko&limit=30`);
    data[c.id] = (await res.json()).items || [];
  } catch { data[c.id] = []; }
}
---

<Layout
  title="What's New — 클라우드 최신 업데이트"
  description="AWS, Google Cloud, Microsoft Azure의 최신 업데이트를 한국어로 요약해 보여주는 클라우드 릴리스 노트 대시보드입니다."
  vendor="home"
>
  <!-- Hero -->
  <div class="text-center py-6 sm:py-16 mb-6">
    <h1 class="text-2xl sm:text-4xl font-bold mb-3" style="color: var(--color-text-primary); font-family: 'Pretendard Variable', var(--font-family);">
      ☁️ What's New 한국어 요약 <span class="text-base sm:text-xl font-normal opacity-50">Beta</span>
    </h1>
    <p class="text-sm sm:text-lg" style="color: var(--color-text-secondary); font-family: 'Pretendard Variable', var(--font-family);">
      Amazon Web Services · Google Cloud · Microsoft Azure<br/>클라우드 최신 업데이트를 한국어로 요약합니다
    </p>
  </div>

  <!-- 3-column layout -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8">
    {csps.map(c => (
      <section>
        <div class="flex items-center justify-between mb-4 pb-2" style={c.isGradient ? `border-image: ${c.color} 1; border-bottom: 3px solid;` : `border-bottom: 3px solid ${c.color};`}>
          <h2 class="text-base sm:text-lg font-bold" style={`color: var(--color-text-primary); font-family: ${c.font}; font-weight: ${c.weight || 700};`}>
            {c.name}
          </h2>
          <a href={`/${c.id}`} class="text-xs font-medium px-2 py-1 rounded" style={`color: ${c.isGradient ? c.accent : c.color}; background: color-mix(in srgb, ${c.isGradient ? c.accent : c.color} 10%, transparent);`}>
            모두 보기 →
          </a>
        </div>
        <ul class="space-y-0">
          {(data[c.id] || []).map((a, i) => (
            <li style={`border-bottom: 1px solid var(--color-border);`}>
              <a href={`/${c.id}#article-${a.article_id}`}
                class="block py-3 px-2 no-underline transition-all duration-150 hover:pl-3 rounded"
                style={`font-family: 'Pretendard Variable', var(--font-family); --item-color: ${c.isGradient ? c.accent : c.color};`}>
                <div class="flex items-start gap-2">
                  <span class="shrink-0 w-1 h-1 rounded-full mt-2" style={`background: ${c.isGradient ? ['#4285F4','#EA4335','#FBBC04','#34A853'][i % 4] : c.color};`}></span>
                  <div class="min-w-0">
                    <p class="text-sm font-medium leading-snug mb-1" style="color: var(--color-text-primary); word-break: break-word;">
                      {a.title}
                    </p>
                    <time class="text-[11px]" style="color: var(--color-text-secondary);">
                      {a.pub_date ? new Date(a.pub_date).toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' }) : ''}
                    </time>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>
