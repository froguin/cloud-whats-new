---
import Layout from '../layouts/Layout.astro';
import UpdateCard from '../components/UpdateCard.astro';

interface Update {
  id: string;
  title: string;
  date: number;
  content: string;
  target?: string;
  features?: string;
  regions?: string;
  status?: string;
  originalLink?: string;
}

interface Meta {
  isCached: boolean;
  lastUpdated: string;
  itemCount: number;
}

let updates: Update[] = [];
let meta: Meta | null = null;
let errorMessage: string | null = null;

try {
  const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://zk0eyxbdxc.execute-api.ap-northeast-2.amazonaws.com/prod';
  const response = await fetch(`${apiUrl}/updates`, {
    method: 'GET',
    headers: {
      'Accept': 'application/json',
    },
  });
  
  if (!response.ok) {
    throw new Error(`HTTP error! status: ${response.status}`);
  }
  
  const data = await response.json();
  updates = data.items;
  meta = data.meta;
} catch (e) {
  console.error('데이터를 가져오는 중 오류가 발생했습니다:', e);
  errorMessage = e instanceof Error ? e.message : '알 수 없는 오류가 발생했습니다';
}
---

<Layout title="AWS What's New 한국어 요약">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {meta && (
      <div class="text-sm text-gray-500 dark:text-gray-400 mb-4">
        <div class="flex justify-between items-center">
          <div>
            마지막 업데이트: {new Date(meta.lastUpdated).toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' })}
            {meta.isCached && <span class="ml-2 text-blue-600 dark:text-blue-400">(캐시됨)</span>}
          </div>
          <div>
            총 {meta.itemCount}개의 업데이트
          </div>
        </div>
      </div>
    )}

    <!-- 검색 입력 -->
    <div class="mb-8">
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input
          type="text"
          id="keyword-search"
          class="block w-full pl-10 pr-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md leading-5 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
          placeholder="키워드로 검색..."
        />
      </div>
    </div>

    {errorMessage ? (
      <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
              데이터를 불러올 수 없습니다
            </h3>
            <div class="mt-2 text-sm text-red-700 dark:text-red-300">
              <p>{errorMessage}</p>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <>
        <!-- 검색 결과 없음 메시지 -->
        <div id="no-results-message" class="hidden text-center py-12">
          <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">검색 결과가 없습니다</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">다른 키워드로 검색해보세요.</p>
        </div>

        <!-- 업데이트 카드들 -->
        <div id="update-cards-container" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {updates.map((update) => (
            <UpdateCard
              title={update.title}
              date={update.date}
              content={update.content}
              target={update.target}
              features={update.features}
              regions={update.regions}
              status={update.status}
              originalLink={update.originalLink}
            />
          ))}
        </div>
      </>
    )}
  </div>

  <!-- 클라이언트 사이드 검색 스크립트 -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('keyword-search') as HTMLInputElement;
      const cards = document.querySelectorAll('.update-card');
      
      if (searchInput) {
        searchInput.addEventListener('input', () => {
          const keyword = searchInput.value.toLowerCase().trim();
          let visibleCount = 0;
          
          cards.forEach(card => {
            const cardText = card.textContent?.toLowerCase() || '';
            const isVisible = keyword === '' || cardText.includes(keyword);
            
            (card as HTMLElement).style.display = isVisible ? 'block' : 'none';
            if (isVisible) visibleCount++;
          });

          // 검색 결과 없을 때 메시지 표시
          const noResultsMessage = document.getElementById('no-results-message');
          const totalCardsContainer = document.getElementById('update-cards-container');
          
          if (visibleCount === 0) {
            noResultsMessage?.classList.remove('hidden');
            totalCardsContainer?.classList.add('hidden');
          } else {
            noResultsMessage?.classList.add('hidden');
            totalCardsContainer?.classList.remove('hidden');
          }
        });
      }
    });
  </script>
</Layout>
