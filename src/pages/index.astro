---
import Layout from '../layouts/Layout.astro';
import UpdateCard from '../components/UpdateCard.astro';

// 업데이트 타입 정의
interface Update {
  title: string;
  date: string;
  content: string;
}

// 서버 사이드에서 데이터 페칭
let updates: Update[] = [];
let errorMessage: string | null = null;

try {
  // Astro.url을 사용하여 전체 URL 구성
  const baseUrl = Astro.url.origin;
  const response = await fetch(`${baseUrl}/.netlify/functions/fetch-updates`, {
    method: 'GET',
    headers: {
      'Accept': 'application/json',
    },
  });
  
  if (!response.ok) {
    throw new Error(`HTTP error! status: ${response.status}`);
  }
  
  updates = await response.json();
} catch (e) {
  console.error('데이터를 가져오는 중 오류가 발생했습니다:', e);
  errorMessage = e instanceof Error ? e.message : '알 수 없는 오류가 발생했습니다';
}
---

<Layout title="AWS What's New 한국어 요약">
  <main class="container mx-auto px-4 py-8">
    {errorMessage ? (
      <div class="error-message">
        <p>데이터를 불러오는 중 오류가 발생했습니다: {errorMessage}</p>
      </div>
    ) : (
      <section class="updates-grid">
        {updates.length > 0 ? (
          updates.map((update) => (
            <UpdateCard {...update} />
          ))
        ) : (
          <div class="no-updates">
            <p>현재 표시할 업데이트가 없습니다.</p>
          </div>
        )}
      </section>
    )}
  </main>

  <style>
    .updates-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
      padding: 1rem;
    }
    .error-message {
      color: red;
      text-align: center;
      padding: 2rem;
    }
    .no-updates {
      text-align: center;
      padding: 2rem;
    }
  </style>
</Layout>
