---
import Layout from '../layouts/Layout.astro';

const API_BASE = import.meta.env.WORKER_URL || 'https://WORKER_URL_REDACTED';

const csps = [
  { id: 'aws', name: 'AWS', color: '#FF9900', accent: '#232F3E' },
  { id: 'gcp', name: 'Google Cloud', color: 'linear-gradient(to right, #4285F4 25%, #EA4335 25%, #EA4335 50%, #FBBC04 50%, #FBBC04 75%, #34A853 75%)', accent: '#4285F4', isGradient: true },
  { id: 'azure', name: 'Azure', color: '#0078D4', accent: '#50E6FF' },
];

const data: Record<string, any[]> = {};
let latestDate = '';
for (const c of csps) {
  try {
    const res = await fetch(`${API_BASE}/api/articles?csp=${c.id}&lang=ko&limit=8`);
    data[c.id] = (await res.json()).items || [];
    for (const a of data[c.id]) {
      if (a.pub_date && a.pub_date > latestDate) latestDate = a.pub_date;
    }
  } catch { data[c.id] = []; }
}
const lastUpdated = latestDate ? new Date(latestDate).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
---

<Layout title="What's New — 클라우드 최신 업데이트" vendor="home">
  <!-- Hero -->
  <div class="text-center py-10 sm:py-16 mb-8">
    <h1 class="text-3xl sm:text-5xl font-bold mb-3" style="color: var(--color-text-primary); font-family: 'Pretendard Variable', var(--font-family);">
      ☁️ What's New 한국어 요약
    </h1>
    <p class="text-base sm:text-xl" style="color: var(--color-text-secondary); font-family: 'Pretendard Variable', var(--font-family);">
      AWS · Google Cloud · Azure 클라우드 최신 업데이트
    </p>
  </div>

  <!-- 3-column layout -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8">
    {csps.map(c => (
      <section>
        <div class="flex items-center justify-between mb-4 pb-2" style={c.isGradient ? `border-image: ${c.color} 1; border-bottom: 3px solid;` : `border-bottom: 3px solid ${c.color};`}>
          <h2 class="text-base sm:text-lg font-bold" style="color: var(--color-text-primary); font-family: 'Pretendard Variable', var(--font-family);">
            {c.name}
          </h2>
          <a href={`/${c.id}`} class="text-xs font-medium px-2 py-1 rounded" style={`color: ${c.isGradient ? c.accent : c.color}; background: color-mix(in srgb, ${c.isGradient ? c.accent : c.color} 10%, transparent);`}>
            모두 보기 →
          </a>
        </div>
        <ul class="space-y-0">
          {(data[c.id] || []).map((a, i) => (
            <li style={`border-bottom: 1px solid var(--color-border);`}>
              <a href={a.url || '#'} target="_blank" rel="noopener noreferrer"
                class="block py-3 px-2 no-underline transition-all duration-150 hover:pl-3 rounded"
                style={`font-family: 'Pretendard Variable', var(--font-family); --item-color: ${c.isGradient ? c.accent : c.color};`}>
                <div class="flex items-start gap-2">
                  <span class="shrink-0 w-1 h-1 rounded-full mt-2" style={`background: ${c.isGradient ? c.accent : c.color};`}></span>
                  <div class="min-w-0">
                    <p class="text-sm font-medium leading-snug mb-1" style="color: var(--color-text-primary); word-break: break-word;">
                      {a.title}
                    </p>
                    <time class="text-[11px]" style="color: var(--color-text-secondary);">
                      {a.pub_date ? new Date(a.pub_date).toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' }) : ''}
                    </time>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>
