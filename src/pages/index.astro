---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AWS What's New 한국어 요약">
  <div class="container mx-auto px-4 py-8">
    <!-- 헤더 -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
        AWS What's New 한국어 요약
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-300">
        최신 AWS 업데이트를 한국어로 쉽게 확인하세요
      </p>
    </div>

    <!-- 로딩 상태 -->
    <div id="loading-state" class="text-center py-12">
      <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
      <p class="mt-4 text-gray-600 dark:text-gray-400">최신 AWS 업데이트를 불러오는 중...</p>
    </div>

    <!-- 메타 정보 및 새로고침 -->
    <div id="meta-section" class="hidden mb-6">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-4 mb-4">
        <div class="flex justify-between items-center">
          <div class="text-sm text-gray-600 dark:text-gray-400">
            <span id="last-updated"></span>
            <span id="cache-status" class="ml-2 px-2 py-1 text-xs bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 rounded"></span>
          </div>
          <div class="flex items-center space-x-4">
            <span class="text-sm text-gray-600 dark:text-gray-400">
              총 <span id="item-count" class="font-semibold">0</span>개
            </span>
            <button 
              id="refresh-btn" 
              class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition-colors duration-200 disabled:opacity-50"
              onclick="refreshData()"
            >
              <span id="refresh-text">새로고침</span>
              <div id="refresh-spinner" class="hidden inline-block ml-2 animate-spin rounded-full h-4 w-4 border-b-2 border-white"></div>
            </button>
          </div>
        </div>
      </div>

      <!-- 검색 -->
      <div class="relative mb-6">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input
          type="text"
          id="keyword-search"
          class="block w-full pl-10 pr-3 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          placeholder="키워드로 검색..."
        />
      </div>
    </div>

    <!-- 오류 메시지 -->
    <div id="error-message" class="hidden bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
            데이터를 불러올 수 없습니다
          </h3>
          <div class="mt-2 text-sm text-red-700 dark:text-red-300">
            <p id="error-text"></p>
          </div>
        </div>
      </div>
    </div>

    <!-- 검색 결과 없음 -->
    <div id="no-results-message" class="hidden text-center py-12">
      <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">검색 결과가 없습니다</h3>
      <p class="text-gray-500 dark:text-gray-400">다른 키워드로 검색해보세요.</p>
    </div>

    <!-- 업데이트 카드들 -->
    <div id="update-cards-container" class="hidden space-y-6">
      <!-- 카드들이 여기에 동적으로 추가됩니다 -->
    </div>
  </div>

  <script is:inline>
    // API URL 설정
    const API_URL = 'https://zk0eyxbdxc.execute-api.ap-northeast-2.amazonaws.com/prod';
    let allUpdates = [];

    document.addEventListener('DOMContentLoaded', () => {
      loadUpdates();
      setupSearch();
    });

    function createUpdateCard(update) {
      return `
        <div class="update-card bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300 p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex justify-between items-start mb-4">
            <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 leading-tight flex-1 mr-4">
              ${update.title}
            </h2>
            <span class="px-3 py-1 text-sm font-medium rounded-full ${getStatusColor(update.status)} whitespace-nowrap">
              ${update.status || '정식출시'}
            </span>
          </div>
          
          <div class="text-sm text-gray-500 dark:text-gray-400 mb-4">
            ${update.date}
          </div>
          
          <p class="text-gray-700 dark:text-gray-300 mb-6 leading-relaxed">
            ${update.content}
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm mb-4">
            ${update.target ? `
              <div class="flex items-center">
                <span class="font-medium text-gray-600 dark:text-gray-400 mr-2">👥 대상:</span>
                <span class="text-gray-700 dark:text-gray-300">${update.target}</span>
              </div>
            ` : ''}
            
            ${update.features ? `
              <div class="flex items-center">
                <span class="font-medium text-gray-600 dark:text-gray-400 mr-2">⚡ 기능:</span>
                <span class="text-gray-700 dark:text-gray-300">${update.features}</span>
              </div>
            ` : ''}
            
            ${update.regions ? `
              <div class="flex items-center">
                <span class="font-medium text-gray-600 dark:text-gray-400 mr-2">🌍 지역:</span>
                <span class="text-gray-700 dark:text-gray-300">${update.regions}</span>
              </div>
            ` : ''}
          </div>
          
          ${update.originalLink ? `
            <div class="pt-4 border-t border-gray-200 dark:border-gray-600">
              <a 
                href="${update.originalLink}" 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors duration-200 font-medium"
              >
                원문 보기
                <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          ` : ''}
        </div>
      `;
    }

    function getStatusColor(status) {
      switch (status) {
        case '미리보기':
          return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/20 dark:text-yellow-400';
        case '베타':
          return 'bg-orange-100 text-orange-800 dark:bg-orange-900/20 dark:text-orange-400';
        case '정식출시':
        default:
          return 'bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-400';
      }
    }

    async function loadUpdates(forceRefresh = false) {
      try {
        showLoading();
        
        const url = forceRefresh ? `${API_URL}/updates?refresh=true` : `${API_URL}/updates`;
        const response = await fetch(url, {
          method: 'GET',
          headers: {
            'Accept': 'application/json',
          },
        });
        
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        allUpdates = data.items || [];
        
        // pubDate 기준으로 최신순 정렬
        allUpdates.sort((a, b) => {
          const dateA = new Date(a.pubDate || a.publishedAt || 0);
          const dateB = new Date(b.pubDate || b.publishedAt || 0);
          return dateB - dateA; // 최신순 (내림차순)
        });
        
        updateMetaInfo(data.meta);
        renderCards(allUpdates);
        hideLoading();
        showContent();
        
      } catch (error) {
        console.error('데이터를 가져오는 중 오류가 발생했습니다:', error);
        showError(error.message || '알 수 없는 오류가 발생했습니다');
        hideLoading();
      }
    }

    async function refreshData() {
      const refreshBtn = document.getElementById('refresh-btn');
      const refreshText = document.getElementById('refresh-text');
      const refreshSpinner = document.getElementById('refresh-spinner');
      
      if (refreshBtn) refreshBtn.disabled = true;
      if (refreshText) refreshText.textContent = '새로고침 중...';
      if (refreshSpinner) refreshSpinner.classList.remove('hidden');
      
      try {
        await loadUpdates(true);
      } finally {
        if (refreshBtn) refreshBtn.disabled = false;
        if (refreshText) refreshText.textContent = '새로고침';
        if (refreshSpinner) refreshSpinner.classList.add('hidden');
      }
    }

    function updateMetaInfo(meta) {
      if (meta) {
        const lastUpdated = new Date(meta.lastUpdated).toLocaleString('ko-KR', { 
          timeZone: 'Asia/Seoul',
          year: 'numeric',
          month: 'long',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        
        const lastUpdatedEl = document.getElementById('last-updated');
        const itemCountEl = document.getElementById('item-count');
        const cacheStatus = document.getElementById('cache-status');
        
        if (lastUpdatedEl) lastUpdatedEl.textContent = `마지막 업데이트: ${lastUpdated}`;
        if (itemCountEl) itemCountEl.textContent = meta.itemCount;
        
        if (cacheStatus) {
          if (meta.isCached) {
            cacheStatus.textContent = '캐시됨';
            cacheStatus.classList.remove('hidden');
          } else {
            cacheStatus.textContent = '최신';
            cacheStatus.classList.remove('hidden');
          }
        }
      }
    }

    function renderCards(updates) {
      const container = document.getElementById('update-cards-container');
      if (container) {
        container.innerHTML = updates.map(update => createUpdateCard(update)).join('');
      }
    }

    function setupSearch() {
      const searchInput = document.getElementById('keyword-search');
      
      if (searchInput) {
        searchInput.addEventListener('input', () => {
          const keyword = searchInput.value.toLowerCase().trim();
          const filteredUpdates = keyword === '' 
            ? allUpdates 
            : allUpdates.filter(update => {
                const searchText = `${update.title} ${update.content} ${update.target} ${update.features} ${update.regions}`.toLowerCase();
                return searchText.includes(keyword);
              });
          
          renderCards(filteredUpdates);
          
          const noResultsMessage = document.getElementById('no-results-message');
          const cardsContainer = document.getElementById('update-cards-container');
          
          if (filteredUpdates.length === 0 && keyword !== '') {
            if (noResultsMessage) noResultsMessage.classList.remove('hidden');
            if (cardsContainer) cardsContainer.classList.add('hidden');
          } else {
            if (noResultsMessage) noResultsMessage.classList.add('hidden');
            if (cardsContainer) cardsContainer.classList.remove('hidden');
          }
        });
      }
    }

    function showLoading() {
      const loadingState = document.getElementById('loading-state');
      if (loadingState) loadingState.classList.remove('hidden');
    }

    function hideLoading() {
      const loadingState = document.getElementById('loading-state');
      if (loadingState) loadingState.classList.add('hidden');
    }

    function showContent() {
      const metaSection = document.getElementById('meta-section');
      const cardsContainer = document.getElementById('update-cards-container');
      
      if (metaSection) metaSection.classList.remove('hidden');
      if (cardsContainer) cardsContainer.classList.remove('hidden');
    }

    function showError(message) {
      const errorText = document.getElementById('error-text');
      const errorMessage = document.getElementById('error-message');
      
      if (errorText) errorText.textContent = message;
      if (errorMessage) errorMessage.classList.remove('hidden');
    }

    window.refreshData = refreshData;
  </script>
</Layout>
