---
import Layout from '../layouts/Layout.astro';
import UpdateCardCloudscape from '../components/UpdateCardCloudscape.astro';

const API_BASE = import.meta.env.WORKER_URL || 'https://WORKER_URL_REDACTED';

const csps = [
  { id: 'aws', name: 'Amazon Web Services', color: '#FF9900' },
  { id: 'gcp', name: 'Google Cloud', color: '#1A73E8' },
  { id: 'azure', name: 'Microsoft Azure', color: '#0078D4' },
];

const data: Record<string, any[]> = {};
for (const c of csps) {
  try {
    const res = await fetch(`${API_BASE}/api/articles?csp=${c.id}&lang=ko&limit=4`);
    data[c.id] = (await res.json()).items || [];
  } catch { data[c.id] = []; }
}
---

<Layout title="What's New — 클라우드 최신 업데이트" vendor="home">
  <div class="text-center mb-8 sm:mb-12">
    <h1 class="text-2xl sm:text-4xl font-bold mb-2" style="color: var(--color-text-primary);">What's New</h1>
    <p class="text-sm sm:text-base" style="color: var(--color-text-secondary);">AWS · Google Cloud · Azure 최신 업데이트</p>
  </div>

  {csps.map(c => (
    <section class="mb-8 sm:mb-12">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg sm:text-xl font-bold flex items-center gap-2" style="color: var(--color-text-primary);">
          <span class="w-3 h-3 rounded-full inline-block" style={`background:${c.color};`}></span>
          {c.name}
        </h2>
        <a href={`/${c.id}`} class="text-xs sm:text-sm font-medium" style={`color:${c.color};`}>
          모두 보기 →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 items-start">
        {(data[c.id] || []).map(a => (
          <UpdateCardCloudscape
            title={a.title} csp={a.csp}
            date={a.pub_date ? new Date(a.pub_date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' }) : ''}
            content={a.summary || ''} target={a.target} features={a.features}
            regions={a.regions} status={a.status} originalLink={a.url} />
        ))}
      </div>
    </section>
  ))}
</Layout>
