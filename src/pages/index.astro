---
import Layout from '../layouts/Layout.astro';
import UpdateCardCloudscape from '../components/UpdateCardCloudscape.astro';

const API_BASE = import.meta.env.WORKER_URL || 'https://WORKER_URL_REDACTED';

let articles: any[] = [];
try {
  const res = await fetch(`${API_BASE}/api/articles?lang=ko&limit=60`);
  articles = (await res.json()).items || [];
} catch (e) { console.error(e); }
---

<Layout title="Cloud What's New — 클라우드 최신 업데이트" vendor="home">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold mb-2" style="color: var(--color-text-primary);">
      ☁️ Cloud What's New
    </h1>
    <p style="color: var(--color-text-secondary);">AWS · GCP · Azure 최신 업데이트를 한국어로</p>
  </div>

  <div class="max-w-md mx-auto mb-8">
    <input type="text" id="search" placeholder="검색..."
      class="w-full px-4 py-2 rounded-lg outline-none transition-colors"
      style="border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-primary);" />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 items-start" id="cards">
    {articles.map(a => (
      <UpdateCardCloudscape
        title={a.title} csp={a.csp}
        date={a.pub_date ? new Date(a.pub_date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }) : ''}
        content={a.summary || ''} target={a.target} features={a.features}
        regions={a.regions} status={a.status} originalLink={a.url} />
    ))}
  </div>

  {articles.length === 0 && (
    <p class="text-center py-16" style="color: var(--color-text-secondary);">데이터를 불러오는 중...</p>
  )}

  <script>
    const s = document.getElementById('search') as HTMLInputElement;
    const c = document.querySelectorAll('#cards > article');
    s?.addEventListener('input', () => {
      const q = s.value.toLowerCase();
      c.forEach(el => { (el as HTMLElement).style.display = (el.textContent?.toLowerCase() || '').includes(q) ? '' : 'none'; });
    });
  </script>
</Layout>
