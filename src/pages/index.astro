---
import Layout from '../layouts/Layout.astro';
import UpdateCard from '../components/UpdateCard.astro';

interface Update {
  title: string;
  date: string;
  content: string;
  target?: string;
  features?: string;
  regions?: string;
  status?: string;
  originalLink?: string;
}

interface Meta {
  isCached: boolean;
  lastUpdated: string;
  itemCount: number;
}

const googleAnalyticsScript = `
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-6K10Z2P301');
`;

// 클라이언트 사이드에서 API 호출 및 필터링을 위한 스크립트
const clientSideScript = `
  let allUpdates = [];
  let meta = null;

  document.addEventListener('DOMContentLoaded', async () => {
    const loadingElement = document.getElementById('loading');
    const errorElement = document.getElementById('error-message');
    const contentElement = document.getElementById('content');
    const searchInput = document.getElementById('keyword-search');

    try {
      // API Gateway 엔드포인트에서 데이터 가져오기
      const apiUrl = '${import.meta.env.PUBLIC_API_URL || 'https://your-api-gateway-url.amazonaws.com/prod'}/updates';
      const response = await fetch(apiUrl);
      
      if (!response.ok) {
        throw new Error(\`HTTP error! status: \${response.status}\`);
      }
      
      const data = await response.json();
      allUpdates = data.items;
      meta = data.meta;
      
      // 메타 정보 표시
      if (meta) {
        const metaElement = document.getElementById('meta-info');
        metaElement.innerHTML = \`
          <div class="flex justify-between items-center">
            <div>
              마지막 업데이트: \${new Date(meta.lastUpdated).toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' })}
              \${meta.isCached ? '<span class="ml-2 text-blue-600 dark:text-blue-400">(캐시됨)</span>' : ''}
            </div>
            <div>
              총 \${meta.itemCount}개의 업데이트
            </div>
          </div>
        \`;
        metaElement.classList.remove('hidden');
      }
      
      // 업데이트 카드 렌더링
      renderUpdates(allUpdates);
      
      // 로딩 숨기고 콘텐츠 표시
      loadingElement.classList.add('hidden');
      contentElement.classList.remove('hidden');
      
    } catch (error) {
      console.error('데이터를 가져오는 중 오류가 발생했습니다:', error);
      loadingElement.classList.add('hidden');
      errorElement.classList.remove('hidden');
      errorElement.innerHTML = \`
        <div class="rounded-md bg-red-50 dark:bg-red-900/50 p-4 my-4">
          <div class="flex">
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800 dark:text-red-200">오류 발생</h3>
              <div class="mt-2 text-sm text-red-700 dark:text-red-300">
                <p>데이터를 불러오는 중 오류가 발생했습니다: \${error.message}</p>
              </div>
            </div>
          </div>
        </div>
      \`;
    }

    // 검색 기능
    searchInput.addEventListener('input', () => {
      const keyword = searchInput.value.toLowerCase().trim();
      const filteredUpdates = keyword === '' 
        ? allUpdates 
        : allUpdates.filter(update => 
            update.title.toLowerCase().includes(keyword) ||
            update.content.toLowerCase().includes(keyword) ||
            (update.target && update.target.toLowerCase().includes(keyword)) ||
            (update.features && update.features.toLowerCase().includes(keyword))
          );
      
      renderUpdates(filteredUpdates);
    });
  });

  function renderUpdates(updates) {
    const container = document.getElementById('update-cards-container');
    const noResultsMessage = document.getElementById('no-results-message');
    
    if (updates.length === 0) {
      container.classList.add('hidden');
      noResultsMessage.classList.remove('hidden');
      return;
    }
    
    container.classList.remove('hidden');
    noResultsMessage.classList.add('hidden');
    
    container.innerHTML = updates.map(update => \`
      <div class="update-card bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
          \${update.title}
        </h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
          \${new Date(update.date).toLocaleDateString('ko-KR')}
        </p>
        <p class="text-gray-700 dark:text-gray-300 mb-4">
          \${update.content}
        </p>
        \${update.target ? \`<div class="mb-2"><span class="text-sm font-medium text-blue-600 dark:text-blue-400">대상:</span> <span class="text-sm text-gray-600 dark:text-gray-400">\${update.target}</span></div>\` : ''}
        \${update.features ? \`<div class="mb-2"><span class="text-sm font-medium text-green-600 dark:text-green-400">주요 기능:</span> <span class="text-sm text-gray-600 dark:text-gray-400">\${update.features}</span></div>\` : ''}
        \${update.regions ? \`<div class="mb-2"><span class="text-sm font-medium text-purple-600 dark:text-purple-400">리전:</span> <span class="text-sm text-gray-600 dark:text-gray-400">\${update.regions}</span></div>\` : ''}
        \${update.status ? \`<div class="mb-4"><span class="text-sm font-medium text-orange-600 dark:text-orange-400">상태:</span> <span class="text-sm text-gray-600 dark:text-gray-400">\${update.status}</span></div>\` : ''}
        \${update.originalLink ? \`<a href="\${update.originalLink}" target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline text-sm">원문 보기 →</a>\` : ''}
      </div>
    \`).join('');
  }
`;
---

<Layout title="AWS What's New 한국어 요약">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- 메타 정보 -->
    <div id="meta-info" class="text-sm text-gray-500 dark:text-gray-400 mb-4 hidden"></div>

    <!-- 검색 필터 -->
    <div class="mb-4">
      <input 
        type="text" 
        id="keyword-search" 
        placeholder="키워드로 검색" 
        class="w-full px-3 py-2 border dark:border-gray-600 rounded-md 
               bg-white dark:bg-gray-700 
               text-gray-900 dark:text-gray-100
               focus:outline-none focus:ring-2 focus:ring-blue-500 
               placeholder-gray-500 dark:placeholder-gray-400"
      />
    </div>

    <!-- 로딩 상태 -->
    <div id="loading" class="text-center py-12">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
      <p class="mt-2 text-gray-500 dark:text-gray-400">데이터를 불러오는 중...</p>
    </div>

    <!-- 오류 메시지 -->
    <div id="error-message" class="hidden"></div>

    <!-- 콘텐츠 -->
    <div id="content" class="hidden">
      <div 
        id="no-results-message" 
        class="hidden col-span-full text-center py-12"
      >
        <p class="text-gray-500 dark:text-gray-400">검색 결과가 없습니다.</p>
      </div>

      <div 
        id="update-cards-container"
        class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 my-6"
      >
        <!-- 동적으로 생성됨 -->
      </div>
    </div>
  </div>

  <script is:inline set:html={clientSideScript}></script>
  <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-6K10Z2P301"></script>
  <script is:inline set:html={googleAnalyticsScript}></script>
</Layout>
